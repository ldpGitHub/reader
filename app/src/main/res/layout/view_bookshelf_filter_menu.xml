<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bookshelf_filter_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.activity.MainActivity">

    <View
        android:id="@+id/bookshelf_filter_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <ImageView
        android:id="@+id/bookshelf_filter_arrow"
        android:layout_width="18dp"
        android:layout_height="10dp"
        android:layout_gravity="top|right"
        android:layout_marginTop="130dp"
        android:layout_marginRight="78dp"
        android:elevation="9dp"
        android:src="@drawable/ic_bookshelf_filter_arrow" />

    <LinearLayout
        android:id="@+id/bookshelf_filter_popup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginLeft="18dp"
        android:layout_marginTop="140dp"
        android:layout_marginRight="18dp"
        android:background="@drawable/bg_bookshelf_filter_popup"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingLeft="22dp"
        android:paddingTop="26dp"
        android:paddingRight="22dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/bookshelf_filter_all"
            android:layout_width="112dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_bookshelf_filter_option_selected"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="全部书籍"
            android:textColor="@color/home_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/bookshelf_filter_status_section"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:text="更新状态"
            android:textColor="@color/home_text_secondary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bookshelf_filter_status_3_days"
                android:layout_width="112dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_bookshelf_filter_option"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="3日内更新"
                android:textColor="@color/home_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/bookshelf_filter_status_7_days"
                android:layout_width="112dp"
                android:layout_height="44dp"
                android:layout_marginLeft="14dp"
                android:background="@drawable/bg_bookshelf_filter_option"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="7日内更新"
                android:textColor="@color/home_text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/bookshelf_filter_progress_section"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:text="阅读进度"
            android:textColor="@color/home_text_secondary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bookshelf_filter_progress_unread"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_bookshelf_filter_option"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="尚未阅读"
                android:textColor="@color/home_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/bookshelf_filter_progress_reading"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginLeft="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_bookshelf_filter_option"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="正在阅读"
                android:textColor="@color/home_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/bookshelf_filter_progress_finished"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginLeft="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_bookshelf_filter_option"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="已读完"
                android:textColor="@color/home_text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/bookshelf_filter_local_section"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:text="本地文件"
            android:textColor="@color/home_text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/bookshelf_filter_local"
            android:layout_width="112dp"
            android:layout_height="44dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_bookshelf_filter_option"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="本地书"
            android:textColor="@color/home_text_primary"
            android:textSize="16sp" />
    </LinearLayout>
</FrameLayout>
