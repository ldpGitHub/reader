<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/home_surface"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@color/home_surface"
            android:paddingRight="18dp"
            android:theme="@style/Theme.ToolBar.Home"
            app:contentInsetStart="0dp"
            app:contentInsetStartWithNavigation="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="left|center_vertical"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/file_system_title"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:drawableRight="@drawable/ic_file_system_dropdown_20"
                    android:drawablePadding="6dp"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:text="智能导入"
                    android:textColor="@color/home_text_primary"
                    android:textSize="22sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/file_system_filter"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:layout_gravity="right|center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="筛选"
                android:padding="10dp"
                android:scaleType="center"
                android:src="@drawable/ic_file_system_filter_28" />

            <ImageButton
                android:id="@+id/file_system_search"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:layout_gravity="right|center_vertical"
                android:layout_marginRight="54dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="搜索"
                android:padding="10dp"
                android:scaleType="center"
                android:src="@drawable/ic_home_search_24" />
        </androidx.appcompat.widget.Toolbar>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_tl_indicator"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/home_surface"
            app:tabIndicatorColor="@color/home_primary"
            app:tabIndicatorHeight="2dp"
            app:tabSelectedTextColor="@color/home_text_primary"
            app:tabTextColor="@color/home_text_tertiary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/tab_vp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="@drawable/bg_file_system_bottom_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <TextView
            android:id="@+id/file_system_selected_count"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:text="已选 0 项"
            android:textColor="@color/home_text_primary"
            android:textSize="18sp" />

        <CheckBox
            android:id="@+id/file_system_cb_selected_all"
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:button="@drawable/selector_file_reader_check"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="全选"
            android:textColor="@color/home_text_primary"
            android:textSize="17sp" />

        <Button
            android:id="@+id/file_system_btn_delete"
            android:layout_width="82dp"
            android:layout_height="44dp"
            android:layout_marginLeft="12dp"
            android:background="@drawable/bg_file_system_delete_button"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="删除"
            android:textColor="@color/home_primary"
            android:textSize="17sp" />

        <Button
            android:id="@+id/file_system_btn_add_book"
            android:layout_width="132dp"
            android:layout_height="44dp"
            android:layout_marginLeft="12dp"
            android:background="@drawable/bg_file_system_add_button"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="加入书架"
            android:textColor="@color/home_text_on_primary"
            android:textSize="17sp" />
    </LinearLayout>
</LinearLayout>
