<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/bg_login_background"
	android:fitsSystemWindows="true">

	<ImageView
		android:id="@+id/iv_login_back"
		android:layout_width="40dp"
		android:layout_height="40dp"
		android:layout_margin="16dp"
		android:background="@drawable/bg_login_button_secondary"
		android:padding="10dp"
		android:scaleType="centerInside"
		android:src="@drawable/ic_close_window" />

	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:fillViewport="true"
		android:paddingBottom="24dp"
		android:paddingLeft="24dp"
		android:paddingRight="24dp"
		android:paddingTop="88dp">

		<FrameLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content">

			<LinearLayout
				android:id="@+id/ll_user_not_login"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/bg_login_panel"
				android:orientation="vertical"
				android:paddingBottom="28dp"
				android:paddingLeft="22dp"
				android:paddingRight="22dp"
				android:paddingTop="26dp">

				<TextView
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="欢迎回来"
					android:textColor="@color/home_text_primary"
					android:textSize="26sp"
					android:textStyle="bold" />

				<TextView
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="8dp"
					android:text="登录后同步书架和阅读进度"
					android:textColor="@color/home_text_secondary"
					android:textSize="14sp" />

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="50dp"
					android:layout_marginTop="28dp"
					android:background="@drawable/bg_login_input"
					android:gravity="center_vertical"
					android:orientation="horizontal"
					android:paddingLeft="14dp"
					android:paddingRight="6dp">

					<EditText
						android:id="@+id/et_user_phone"
						android:layout_width="0dp"
						android:layout_height="match_parent"
						android:layout_weight="1"
						android:background="@null"
						android:hint="请输入手机号码"
						android:inputType="phone"
						android:maxLines="1"
						android:singleLine="true"
						android:textColor="@color/home_text_primary"
						android:textColorHint="@color/home_text_secondary"
						android:textSize="14sp" />

					<Button
						android:id="@+id/btn_get_sms_code"
						android:layout_width="104dp"
						android:layout_height="38dp"
						android:background="@drawable/bg_login_button_secondary"
						android:gravity="center"
						android:stateListAnimator="@null"
						android:text="获取验证码"
						android:textAllCaps="false"
						android:textColor="@color/home_primary_dark"
						android:textSize="13sp" />
				</LinearLayout>

				<EditText
					android:id="@+id/et_sms_code_input"
					android:layout_width="match_parent"
					android:layout_height="50dp"
					android:layout_marginTop="12dp"
					android:background="@drawable/bg_login_input"
					android:hint="请输入验证码"
					android:inputType="textPassword"
					android:maxLines="1"
					android:paddingLeft="14dp"
					android:paddingRight="14dp"
					android:singleLine="true"
					android:textColor="@color/home_text_primary"
					android:textColorHint="@color/home_text_secondary"
					android:textSize="14sp" />

				<Button
					android:id="@+id/btn_user_login"
					android:layout_width="match_parent"
					android:layout_height="50dp"
					android:layout_marginTop="24dp"
					android:background="@drawable/bg_login_button_primary"
					android:stateListAnimator="@null"
					android:text="验证码登录"
					android:textAllCaps="false"
					android:textColor="@color/home_text_on_primary"
					android:textSize="16sp" />

				<Button
					android:id="@+id/btn_direct_login"
					android:layout_width="match_parent"
					android:layout_height="50dp"
					android:layout_marginTop="12dp"
					android:background="@drawable/bg_login_button_secondary"
					android:gravity="center"
					android:stateListAnimator="@null"
					android:text="本机号码一键登录"
					android:textAllCaps="false"
					android:textColor="@color/home_primary_dark"
					android:textSize="16sp" />
			</LinearLayout>

			<LinearLayout
				android:id="@+id/ll_user_login"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/bg_login_panel"
				android:gravity="center_horizontal"
				android:orientation="vertical"
				android:paddingBottom="30dp"
				android:paddingLeft="22dp"
				android:paddingRight="22dp"
				android:paddingTop="32dp"
				android:visibility="gone"
				tools:visibility="visible">

				<ImageView
					android:id="@+id/iv_user_logo"
					android:layout_width="72dp"
					android:layout_height="72dp"
					android:background="@drawable/bg_home_book_cover"
					android:padding="14dp"
					android:scaleType="centerCrop"
					android:src="@drawable/ic_user_logo" />

				<TextView
					android:id="@+id/tv_user_name"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="16dp"
					android:textColor="@color/home_text_primary"
					android:textSize="18sp"
					android:textStyle="bold"
					tools:text="reader_user" />

				<Button
					android:id="@+id/btn_user_logout"
					android:layout_width="match_parent"
					android:layout_height="50dp"
					android:layout_marginTop="28dp"
					android:background="@drawable/bg_login_button_secondary"
					android:stateListAnimator="@null"
					android:text="退出登录"
					android:textAllCaps="false"
					android:textColor="@color/home_primary_dark"
					android:textSize="16sp" />
			</LinearLayout>
		</FrameLayout>
	</ScrollView>
</FrameLayout>
