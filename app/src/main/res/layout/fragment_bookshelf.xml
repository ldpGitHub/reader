<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/home_bg"
	android:orientation="vertical"
	android:paddingLeft="12dp"
	android:paddingRight="12dp"
	android:paddingTop="10dp">

	<LinearLayout
		android:id="@+id/home_hero_panel"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="@drawable/bg_home_hero_panel"
		android:orientation="vertical"
		android:paddingBottom="14dp"
		android:paddingLeft="14dp"
		android:paddingRight="14dp"
		android:paddingTop="14dp">

		<TextView
			android:id="@+id/home_hero_title"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:ellipsize="end"
			android:includeFontPadding="false"
			android:maxLines="1"
			android:text="今晚读点什么"
			android:textColor="@color/home_text_primary"
			android:textSize="20sp"
			android:textStyle="bold" />

		<TextView
			android:id="@+id/home_hero_subtitle"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="7dp"
			android:ellipsize="end"
			android:includeFontPadding="false"
			android:maxLines="1"
			android:text="搜索、导入和同步都从这里开始"
			android:textColor="@color/home_text_secondary"
			android:textSize="12sp" />

		<LinearLayout
			android:id="@+id/home_search_entry"
			android:layout_width="match_parent"
			android:layout_height="42dp"
			android:layout_marginTop="13dp"
			android:background="@drawable/bg_home_search_pill"
			android:clickable="true"
			android:focusable="true"
			android:foreground="?attr/selectableItemBackground"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:paddingLeft="12dp"
			android:paddingRight="12dp">

			<ImageView
				android:layout_width="18dp"
				android:layout_height="18dp"
				android:src="@drawable/ic_menu_search"
				app:tint="@color/home_text_secondary" />

			<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_marginLeft="8dp"
				android:layout_weight="1"
				android:ellipsize="end"
				android:includeFontPadding="false"
				android:maxLines="1"
				android:text="搜索书名或作者"
				android:textColor="@color/home_text_secondary"
				android:textSize="13sp" />
		</LinearLayout>

		<LinearLayout
			android:id="@+id/home_quick_actions"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:baselineAligned="false"
			android:orientation="horizontal">

			<TextView
				android:id="@+id/home_action_search"
				android:layout_width="0dp"
				android:layout_height="38dp"
				android:layout_marginRight="8dp"
				android:layout_weight="1"
				android:background="@drawable/bg_home_quick_chip"
				android:clickable="true"
				android:drawableLeft="@drawable/ic_home_search_24"
				android:drawablePadding="5dp"
				android:focusable="true"
				android:gravity="center"
				android:includeFontPadding="false"
				android:text="找书"
				android:textColor="@color/home_primary_dark"
				android:textSize="12sp" />

			<TextView
				android:id="@+id/home_action_import"
				android:layout_width="0dp"
				android:layout_height="38dp"
				android:layout_marginLeft="4dp"
				android:layout_marginRight="4dp"
				android:layout_weight="1"
				android:background="@drawable/bg_home_quick_chip"
				android:clickable="true"
				android:drawableLeft="@drawable/ic_home_import_24"
				android:drawablePadding="5dp"
				android:focusable="true"
				android:gravity="center"
				android:includeFontPadding="false"
				android:text="导入"
				android:textColor="@color/home_primary_dark"
				android:textSize="12sp" />

			<TextView
				android:id="@+id/home_action_sync"
				android:layout_width="0dp"
				android:layout_height="38dp"
				android:layout_marginLeft="8dp"
				android:layout_weight="1"
				android:background="@drawable/bg_home_quick_chip"
				android:clickable="true"
				android:drawableLeft="@drawable/ic_home_sync_24"
				android:drawablePadding="5dp"
				android:focusable="true"
				android:gravity="center"
				android:includeFontPadding="false"
				android:text="同步"
				android:textColor="@color/home_primary_dark"
				android:textSize="12sp" />
		</LinearLayout>
	</LinearLayout>

	<LinearLayout
		android:id="@+id/home_shelf_summary"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="12dp"
		android:background="@drawable/bg_home_summary"
		android:gravity="center_vertical"
		android:orientation="horizontal">

		<View
			android:layout_width="4dp"
			android:layout_height="38dp"
			android:background="@drawable/bg_home_section_mark" />

		<LinearLayout
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_marginLeft="12dp"
			android:layout_weight="1"
			android:orientation="vertical">

			<TextView
				android:id="@+id/home_shelf_title"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:ellipsize="end"
				android:includeFontPadding="false"
				android:maxLines="1"
				android:text="继续阅读"
				android:textColor="@color/home_text_primary"
				android:textSize="15sp"
				android:textStyle="bold" />

			<TextView
				android:id="@+id/home_shelf_subtitle"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="6dp"
				android:ellipsize="end"
				android:includeFontPadding="false"
				android:maxLines="1"
				android:text="从最近章节接着读"
				android:textColor="@color/home_text_secondary"
				android:textSize="11sp" />
		</LinearLayout>
	</LinearLayout>

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginBottom="8dp"
		android:layout_marginTop="14dp"
		android:gravity="center_vertical"
		android:orientation="horizontal">

		<View
			android:layout_width="3dp"
			android:layout_height="15dp"
			android:background="@drawable/bg_home_section_mark" />

		<TextView
			android:id="@+id/home_section_title"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginLeft="8dp"
			android:includeFontPadding="false"
			android:text="我的书架"
			android:textColor="@color/home_text_primary"
			android:textSize="14sp"
			android:textStyle="bold" />
	</LinearLayout>

	<com.ldp.reader.widget.refresh.ScrollRefreshRecyclerView
		android:id="@+id/book_shelf_rv_content"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1"
		app:layout_scroll_empty="@layout/view_empty_book_shelf" />
</LinearLayout>
