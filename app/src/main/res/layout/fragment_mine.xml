<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mine_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="72dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="98dp">

            <LinearLayout
                android:id="@+id/mine_profile_card"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_gravity="left|bottom"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingRight="6dp">

                <TextView
                    android:id="@+id/mine_profile_avatar"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/ic_mine_avatar_default"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text=""
                    android:textColor="@color/home_text_on_primary"
                    android:textSize="0sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/mine_profile_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="未登录"
                        android:textColor="@color/mine_text_primary"
                        android:textSize="21sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/mine_profile_reading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="累计读0小时 | 今日读0分钟"
                        android:textColor="@color/mine_text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <TextView
                    android:id="@+id/mine_login_entry"
                    android:layout_width="74dp"
                    android:layout_height="40dp"
                    android:drawableRight="@drawable/ic_reader_arrow_18"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="去登录"
                    android:textColor="@color/mine_text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_mine_panel"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp">

            <LinearLayout
                android:id="@+id/mine_reading_entry"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:text="阅读时长"
                    android:textColor="@color/mine_text_primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/mine_reading_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="累计读0小时 | 今日读0分钟"
                    android:textColor="@color/mine_text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginLeft="8dp"
                    android:src="@drawable/ic_reader_arrow_18" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/mine_line" />

            <TextView
                android:id="@+id/mine_books_entry"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:clickable="true"
                android:drawableRight="@drawable/ic_reader_arrow_18"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text="我的书籍"
                android:textColor="@color/mine_text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_mine_panel"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp">

            <TextView
                android:id="@+id/mine_settings_entry"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:clickable="true"
                android:drawableRight="@drawable/ic_reader_arrow_18"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text="设置"
                android:textColor="@color/mine_text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/mine_line" />

            <TextView
                android:id="@+id/mine_about_entry"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:clickable="true"
                android:drawableRight="@drawable/ic_reader_arrow_18"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text="关于本应用"
                android:textColor="@color/mine_text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
